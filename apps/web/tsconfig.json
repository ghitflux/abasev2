{
  "extends": "../../packages/tsconfig/nextjs.json",
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "allowJs": false,
    "baseUrl": ".",
    "incremental": false,
    "noEmit": true,
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "next-env.typecheck.d.ts",
    "jest.setup.ts",
    "src/**/*.ts",
    "src/**/*.tsx"
  ],
  "exclude": [
    ".next",
    "coverage",
    "node_modules",
    "src/gen/**/*"
  ]
}
