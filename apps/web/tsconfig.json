{
  "extends": "../../packages/tsconfig/nextjs.json",
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "allowJs": false,
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "incremental": false,
    "noEmit": true,
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "jest.setup.ts",
    "src/**/*.ts",
    "src/**/*.tsx"
  ],
  "exclude": [".next", "coverage", "node_modules"]
}
