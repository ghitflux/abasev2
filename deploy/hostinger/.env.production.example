# ============================================================
# ABASE v2 — Arquivo de Ambiente de Produção (EXEMPLO)
# ============================================================
# COPIE este arquivo para /opt/ABASE/env/.env.production
# NUNCA commite o arquivo real com segredos preenchidos
# Gere SECRET_KEY com: python -c "import secrets; print(secrets.token_urlsafe(64))"
# ============================================================

COMPOSE_PROJECT_NAME=abase

# ── Django ──────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=config.settings.production
SECRET_KEY=TROQUE_ISTO_gere_com_python_secrets_token_urlsafe_64
DEBUG=False
ALLOWED_HOSTS=abasepiaui.cloud,www.abasepiaui.cloud
CSRF_TRUSTED_ORIGINS=https://abasepiaui.cloud,https://www.abasepiaui.cloud
CORS_ALLOWED_ORIGINS=https://abasepiaui.cloud,https://www.abasepiaui.cloud

# ── MySQL ────────────────────────────────────────────────────
DATABASE_NAME=abase_v2
DATABASE_USER=abase
DATABASE_PASSWORD=TROQUE_ISTO_senha_forte_aqui
DATABASE_HOST=mysql
DATABASE_PORT=3306

MYSQL_ROOT_PASSWORD=TROQUE_ISTO_root_password_forte
MYSQL_DATABASE=abase_v2
MYSQL_USER=abase
MYSQL_PASSWORD=TROQUE_ISTO_senha_forte_aqui

# ── Redis / Celery ───────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── JWT ──────────────────────────────────────────────────────
JWT_ACCESS_TOKEN_LIFETIME=2880
JWT_REFRESH_TOKEN_LIFETIME=10080

# ── Frontend Next.js ─────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://abasepiaui.cloud/api/v1
INTERNAL_API_URL=http://backend:8000/api/v1
NODE_ENV=production

# ── SSL (Certbot) ────────────────────────────────────────────
CERTBOT_EMAIL=ghitflux@gmail.com
DOMAIN=abasepiaui.cloud
